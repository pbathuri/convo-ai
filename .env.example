# --- OpenAI (required for Docker / Render / Railway / Fly unless you use private Ollama) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# --- Ollama (local) — takes precedence when USE_OLLAMA is true ---
USE_OLLAMA=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=ollama
